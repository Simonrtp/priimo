# =====================================================================
# Priimo Landing — Environment Variables (template)
#
# Copy this file to `.env.local` for local development, or paste the
# variables into Vercel → Project → Settings → Environment Variables for
# production / preview.
#
# All variables are OPTIONAL — the site builds and runs without them.
# =====================================================================

# Public site URL (used for canonical, OG, sitemap, robots).
# In production, set this to your custom domain (e.g. https://priimo.fr).
# In Vercel previews, leave unset — VERCEL_URL is injected automatically.
NEXT_PUBLIC_SITE_URL=

# URL Calendly cible pour tous les CTA "Réserver une démo" de la landing.
# Si vide, le fallback hardcodé dans lib/calendly.ts est utilisé.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/simon-ropiot44/nouvelle-reunion

# Optional outbound webhook called by /api/beta on every successful form
# submission. Compatible with Slack, Discord, Make.com, n8n, Zapier, or
# any HTTP endpoint accepting a JSON POST body.
# Example: https://hooks.slack.com/services/T0000/B0000/XXXX
BETA_WEBHOOK_URL=

# --- Optional: one JSON file per beta signup on Vercel Blob (no Make / no DB) ---
# 1. In Vercel → Storage → Create Blob store → link to this project.
# 2. Vercel injects BLOB_READ_WRITE_TOKEN automatically in production.
# 3. Set BETA_BLOB_STORE=1 to enable uploads from /api/beta.
# Files appear as beta-signups/YYYY-MM-DD/<id>.json in the Blob browser.
BETA_BLOB_STORE=
# BLOB_READ_WRITE_TOKEN=   # copy from Vercel for local .env.local only
